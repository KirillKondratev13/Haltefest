# Copy to .env and fill required values.
#
# GigaChat credentials (choose ONE option):
# Option A (recommended for this project): ready authorization key from Sber cabinet.
# This value is sent as 'Authorization: Basic <key>' while requesting OAuth token.
GIGACHAT_AUTH_KEY=
#
# Option B: provide client pair and service will build Base64(client_id:client_secret).
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=

# GigaChat API runtime config
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_TIMEOUT_SECONDS=120

# SSL verification for GigaChat HTTPS calls.
# true  -> verify certificates (recommended for production)
# false -> allow local/dev startup without local cert chain setup
GIGACHAT_VERIFY_SSL=false

# Token refresh buffer (seconds before expiry)
GIGACHAT_TOKEN_REFRESH_SKEW_SECONDS=60

# Hybrid retrieval + reranker
DOC_CHAT_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
DOC_CHAT_SEMANTIC_TOP_K=10
DOC_CHAT_BM25_TOP_K=10
DOC_CHAT_RRF_K=60
DOC_CHAT_HYBRID_FUSED_LIMIT=40
DOC_CHAT_BM25_PAGE_SIZE=256
DOC_CHAT_BM25_MAX_CHUNKS=3000
DOC_CHAT_RERANK_TOP_K=20

# Local Ollama context window.
# Increase if your model/GPU supports it (e.g. 8192, 16384) to allow larger prompts.
OLLAMA_NUM_CTX=4096

# Doc-chat prompt budget controls.
# If DOC_CHAT_SINGLE_DOC_THRESHOLD_TOKENS=0, threshold is auto-calculated from budget below.
DOC_CHAT_MODEL_CONTEXT_WINDOW_TOKENS=32000
DOC_CHAT_SINGLE_DOC_THRESHOLD_TOKENS=0
DOC_CHAT_RESERVED_SYSTEM_TOKENS=400
DOC_CHAT_RESERVED_HISTORY_TOKENS=0
DOC_CHAT_RESERVED_OUTPUT_TOKENS=700
DOC_CHAT_SAFETY_MARGIN_TOKENS=300
DOC_CHAT_CONTEXT_MAX_CHARS=18000

RERANKER_URL=http://reranker:8090
RERANKER_TIMEOUT_SECONDS=60
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu
RERANKER_BATCH_SIZE=16
RERANKER_MAX_CANDIDATES=200
RERANKER_DEFAULT_TOP_K=40
