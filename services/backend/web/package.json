{
	"devDependencies": {
		"daisyui": "4.12.24",
		"esbuild": "0.25.1",
		"tailwindcss": "^3.4.17"
	},
	"scripts": {
		"build:css": "npx tailwindcss -i src/main.css -o public/assets/main.css",
		"build:js": "npx esbuild src/main.js --bundle --outfile=public/assets/main.js --format=esm --external:fs --external:path --loader:.js=jsx",
		"watch:css": "npm run build:css -- --watch",
		"watch:js": "npm run build:js -- --watch=forever"
	},
	"dependencies": {
		"htmx.org": "^2.0.2",
		"vis-data": "^7.1.9",
		"vis-network": "^9.1.9",
		"@egjs/hammerjs": "^2.0.17",
		"keycharm": "^0.4.0",
		"uuid": "^9.0.1",
		"vis-util": "^5.0.7"
	}
}
